{
  "manifest_version": 3,
  "name": "DevMaker",
  "version": "2.0.0",
  "description": "Browser automation bridge for DevMaker",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": ["*://x.com/*", "*://twitter.com/*", "*://*.railway.app/*", "*://localhost/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["lib/block-beforeunload.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["lib/human.js", "lib/scraper.js", "lib/actions.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
